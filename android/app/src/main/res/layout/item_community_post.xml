<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="1dp"
    app:cardCornerRadius="0dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/space_md">

        <LinearLayout
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginEnd="@dimen/space_md">

            <ImageView
                android:id="@+id/ivUpvote"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_thumbs_up"
                android:tint="@color/muted_foreground"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="2dp" />

            <TextView
                android:id="@+id/tvVotes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12"
                android:textColor="@color/foreground"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp" />

            <ImageView
                android:id="@+id/ivDownvote"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_thumbs_down"
                android:tint="@color/muted_foreground"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="2dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvAuthor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="u/username"
                    android:textColor="@color/foreground"
                    android:textSize="@dimen/text_xs"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="@color/muted_foreground"
                    android:textSize="@dimen/text_xs" />

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2h ago"
                    android:textColor="@color/muted_foreground"
                    android:textSize="@dimen/text_xs" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This is a community post message"
                android:textColor="@color/foreground"
                android:textSize="@dimen/text_base"
                android:lineSpacingExtra="2dp"
                android:layout_marginTop="@dimen/space_xs" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/space_sm"
                android:gravity="center_vertical">

                <LinearLayout
                    android:id="@+id/btnReply"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:paddingStart="@dimen/space_xs"
                    android:paddingEnd="@dimen/space_sm"
                    android:paddingTop="@dimen/space_xs"
                    android:paddingBottom="@dimen/space_xs">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_reply"
                        android:tint="@color/muted_foreground" />

                    <TextView
                        android:id="@+id/tvReplies"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 replies"
                        android:textColor="@color/muted_foreground"
                        android:textSize="@dimen/text_xs"
                        android:textStyle="bold"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnShare"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:paddingStart="@dimen/space_sm"
                    android:paddingEnd="@dimen/space_sm"
                    android:paddingTop="@dimen/space_xs"
                    android:paddingBottom="@dimen/space_xs"
                    android:layout_marginStart="@dimen/space_xs">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_share"
                        android:tint="@color/muted_foreground" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Share"
                        android:textColor="@color/muted_foreground"
                        android:textSize="@dimen/text_xs"
                        android:textStyle="bold"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
