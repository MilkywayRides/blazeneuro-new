<?xml version="1.0" encoding="utf-8"?>
<!-- shadcn-inspired Welcome Screen -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/space_xl">

    <!-- Spacer top -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Logo mark -->
    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="center"
        android:background="@drawable/card_background">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="⚡"
            android:textSize="32sp" />
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/space_xl"
        android:fontFamily="sans-serif-medium"
        android:text="BlazeNeuro"
        android:textColor="@color/foreground"
        android:textSize="@dimen/text_3xl" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/space_sm"
        android:text="Your intelligent workspace"
        android:textColor="@color/muted_foreground"
        android:textSize="@dimen/text_base" />

    <!-- Spacer -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Actions -->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:background="@drawable/button_primary"
        android:fontFamily="sans-serif-medium"
        android:text="Log in"
        android:textAllCaps="false"
        android:textColor="@color/primary_foreground"
        android:textSize="@dimen/text_sm" />

    <Button
        android:id="@+id/btnSignup"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="@dimen/space_md"
        android:background="@drawable/button_outline"
        android:fontFamily="sans-serif-medium"
        android:text="Create account"
        android:textAllCaps="false"
        android:textColor="@color/foreground"
        android:textSize="@dimen/text_sm" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/space_xl"
        android:layout_marginBottom="@dimen/space_lg"
        android:text="By continuing, you agree to our Terms of Service"
        android:textColor="@color/text_muted"
        android:textSize="@dimen/text_xs" />

</LinearLayout>
