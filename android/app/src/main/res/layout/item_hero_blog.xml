<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_background"
    android:layout_marginBottom="@dimen/space_lg">

    <ImageView
        android:id="@+id/ivHeroCover"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_home" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_md">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Latest"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/space_xs" />

        <TextView
            android:id="@+id/tvHeroTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Blog Title"
            android:textColor="@color/foreground"
            android:textSize="20sp"
            android:textStyle="bold"
            android:maxLines="3"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvHeroDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Blog description..."
            android:textColor="@color/muted_foreground"
            android:textSize="14sp"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginTop="@dimen/space_sm" />

    </LinearLayout>

</LinearLayout>
